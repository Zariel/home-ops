{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>home-operations/renovate-presets',
    'github>zariel/home-ops//.renovate/allowedVersions.json5',
    'github>zariel/home-ops//.renovate/autoMerge.json5',
    'github>zariel/home-ops//.renovate/customManagers.json5',
    'github>zariel/home-ops//.renovate/grafanaDashboards.json5',
    'github>zariel/home-ops//.renovate/groups.json5',
    ':semanticCommits',
    ':timezone(Europe/London)',
  ],
  suppressNotifications: [
    'prEditedNotification',
    'prIgnoreNotification',
  ],
  ignorePaths: [
    '**/*.sops.*',
    '**/resources/**',
    '**/ansible/**',
  ],
  packageRules: [
    {
      // Docker-based GitHub Actions from GHCR may not expose release timestamps,
      // which can leave updates permanently pending when minimumReleaseAge is set.
      matchManagers: ["github-actions"],
      matchDatasources: ["docker"],
      minimumReleaseAge: "0 days",
    },
    {
      matchPackageNames: ["home-operations/flate", "home-operations/flate/action"],
      minimumReleaseAge: "0 days",
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
    },
  ],
}
