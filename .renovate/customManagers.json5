{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "allowedCommands": [
    "^\\.renovate/scripts/update-catppuccin-gitea\\.sh$"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": ["Process annotated URL dependencies"],
      "managerFilePatterns": [
        "/(^|/)k8s/.+\\.ya?ml(\\.j2)?$/",
      ],
      "matchStrings": [
        // # renovate: datasource=github-releases depName=rancher/system-upgrade-controller
        // https://github.com/rancher/system-upgrade-controller/releases/download/v0.13.2/crd.yaml
        "(?m:# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n.+?\/(?<currentValue>(v|\\d)[^\/]+)\\S+$)"
      ],
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}"
    }
  ],
  "packageRules": [
    {
      "description": ["Refresh vendored Forgejo Catppuccin theme CSS"],
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["catppuccin/gitea"],
      "postUpgradeTasks": {
        "commands": [
          ".renovate/scripts/update-catppuccin-gitea.sh"
        ],
        "fileFilters": [
          "k8s/apps/default/forgejo/app/themes/theme-catppuccin-mocha-lavender.css"
        ],
        "executionMode": "update"
      }
    }
  ]
}
