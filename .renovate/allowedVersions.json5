{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "allowedVersions": "<999",
      "matchPackageNames": ["/kopia/"]
    },
    {
      "matchDatasources": ["docker"],
      "allowedVersions": "<=16",
      "matchPackageNames": ["/postgresql/"]
    }
  ]
}
