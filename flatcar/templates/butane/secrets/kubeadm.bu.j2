variant: flatcar
version: 1.1.0
storage:
  files:
    - path: /etc/kubeadm/kubeadm.yaml
      mode: 0600
      contents:
        inline: |
{{ kubeadm_config | indent(10, true) }}
    - path: /opt/bin/kubeadm-bootstrap
      mode: 0755
      contents:
        inline: |
          #!/usr/bin/env bash
          set -euo pipefail

          state_dir="/var/lib/flatcar-kubeadm"
          complete="${state_dir}/complete"
          local_readyz="https://127.0.0.1:6443/readyz"
          cluster_readyz="https://{{ cluster.control_plane_endpoint }}/readyz"
          mkdir -p "${state_dir}"

          log() {
            echo "kubeadm-bootstrap: $*" >&2
          }

          readyz() {
            curl --silent --fail --insecure --max-time 5 "$1" >/dev/null
          }

          wait_readyz() {
            local url="$1"
            local timeout="$2"
            local deadline=$((SECONDS + timeout))

            until readyz "${url}"; do
              if [[ "${SECONDS}" -ge "${deadline}" ]]; then
                log "timed out waiting for ${url}"
                return 1
              fi
              sleep 5
            done
          }

{% if node.bootstrap %}
          install_core_kubeconfig() {
            if [[ ! -s /etc/kubernetes/admin.conf ]]; then
              log "admin.conf is missing"
              return 1
            fi
            mkdir -p /home/core/.kube
            cp /etc/kubernetes/admin.conf /home/core/.kube/config
            chown -R core:core /home/core/.kube
          }
{% endif %}

          mark_complete() {
            touch "${complete}"
            log "kubeadm bootstrap completed"
          }

          verify_control_plane() {
            if [[ ! -s /etc/kubernetes/kubelet.conf ]]; then
              log "kubelet.conf is missing"
              return 1
            fi
            if [[ ! -s /etc/kubernetes/manifests/kube-apiserver.yaml ]]; then
              log "kube-apiserver static pod manifest is missing"
              return 1
            fi
            wait_readyz "${local_readyz}" 300
{% if node.bootstrap %}
            install_core_kubeconfig
{% endif %}
            mark_complete
          }

          if [[ -e "${complete}" ]]; then
            exit 0
          fi

          if [[ -s /etc/kubernetes/manifests/kube-apiserver.yaml ]]; then
            log "control-plane manifest already exists; verifying before marking complete"
            verify_control_plane
            exit 0
          fi

          systemctl reset-failed kubelet.service || true

{% if node.bootstrap %}
          log "pulling Kubernetes control-plane images"
          kubeadm config images pull --config /etc/kubeadm/kubeadm.yaml
          log "running kubeadm init"
          kubeadm init --upload-certs --config /etc/kubeadm/kubeadm.yaml
{% else %}
          log "waiting for bootstrap API endpoint"
          wait_readyz "${cluster_readyz}" 300
          log "running kubeadm join"
          kubeadm join --config /etc/kubeadm/kubeadm.yaml
{% endif %}
          verify_control_plane
{% if node.bootstrap %}
    - path: /etc/kubernetes/pki/ca.crt
      mode: 0644
      contents:
        inline: |
{{ secrets.kubeadm_ca_crt | indent(10, true) }}
    - path: /etc/kubernetes/pki/ca.key
      mode: 0600
      contents:
        inline: |
{{ secrets.kubeadm_ca_key | indent(10, true) }}
    - path: /opt/bin/kubeadm-upload-certs
      mode: 0700
      contents:
        inline: |
          #!/usr/bin/env bash
          set -euo pipefail

          curl --silent --fail --insecure --max-time 5 https://127.0.0.1:6443/readyz >/dev/null
          kubeadm init phase upload-certs \
            --upload-certs \
            --certificate-key {{ secrets.kubeadm_certificate_key }} \
            --config /etc/kubeadm/kubeadm.yaml \
            --skip-certificate-key-print
systemd:
  units:
    - name: kubeadm-upload-certs.service
      contents: |
        [Unit]
        Description=Refresh kubeadm control-plane certificate upload secret
        After=kubeadm.service
        ConditionPathExists=/var/lib/flatcar-kubeadm/complete

        [Service]
        Type=oneshot
        Environment="PATH=/opt/bin:/usr/sbin:/usr/bin"
        ExecStart=/opt/bin/kubeadm-upload-certs
    - name: kubeadm-upload-certs.timer
      enabled: true
      contents: |
        [Unit]
        Description=Refresh kubeadm uploaded control-plane certificates periodically

        [Timer]
        OnBootSec=10min
        OnUnitActiveSec=1h
        AccuracySec=5min
        Unit=kubeadm-upload-certs.service

        [Install]
        WantedBy=timers.target
{% endif %}
