{
  "id": "{{ node.hostname }}-node",
  "name": "{{ node.hostname }}-node",
  "ignition_id": "nodes/{{ node.hostname }}.ign",
  "boot": {
    "kernel": "/assets/flatcar/current/flatcar_production_pxe.vmlinuz",
    "initrd": [
      "/assets/flatcar/current/flatcar_production_pxe_image.cpio.gz"
    ],
    "args": [
      "initrd=flatcar_production_pxe_image.cpio.gz",
      "flatcar.first_boot=1",
      "flatcar.autologin",
      "ignition.config.url={{ matchbox_http_base }}/ignition?mac=${mac:hexhyp}&stage=node"
    ]
  }
}
