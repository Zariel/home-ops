apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
bootstrapTokens:
  - token: {{ secrets.kubeadm_token }}
    ttl: 0s
certificateKey: {{ secrets.kubeadm_certificate_key }}
localAPIEndpoint:
  advertiseAddress: {{ node.bond_ip | split("/") | first }}
  bindPort: 6443
nodeRegistration:
  name: {{ node.hostname }}
  criSocket: unix:///run/containerd/containerd.sock
  taints: []
  kubeletExtraArgs:
    - name: node-ip
      value: {{ node.bond_ip | split("/") | first }}
patches:
  directory: /etc/kubernetes/patches
skipPhases:
  - addon/kube-proxy
  - addon/coredns
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
clusterName: {{ cluster.name }}
kubernetesVersion: {{ bakery.kubernetes.version }}
controlPlaneEndpoint: {{ cluster.control_plane_endpoint }}
certificatesDir: /etc/kubernetes/pki
networking:
  dnsDomain: {{ cluster.dns_domain }}
  podSubnet: {{ cluster.pod_cidr }}
  serviceSubnet: {{ cluster.service_cidr }}
proxy:
  disabled: true
apiServer:
  certSANs:
    - {{ cluster.control_plane_endpoint | split(":") | first }}
    - {{ cluster.api_server_vip }}
    - 127.0.0.1
  extraArgs:
    - name: feature-gates
      value: MutatingAdmissionPolicy=true
    - name: runtime-config
      value: admissionregistration.k8s.io/v1beta1=true
    - name: anonymous-auth
      value: "true"
    - name: audit-policy-file
      value: /etc/kubernetes/audit-policy.yaml
  extraVolumes:
    - name: audit-policy
      hostPath: /etc/kubernetes/audit-policy.yaml
      mountPath: /etc/kubernetes/audit-policy.yaml
      readOnly: true
      pathType: File
controllerManager:
  extraArgs:
    - name: bind-address
      value: 0.0.0.0
scheduler:
  extraArgs:
    - name: bind-address
      value: 0.0.0.0
    - name: config
      value: /etc/kubernetes/scheduler-config.yaml
  extraVolumes:
    - name: scheduler-config
      hostPath: /etc/kubernetes/scheduler-config.yaml
      mountPath: /etc/kubernetes/scheduler-config.yaml
      readOnly: true
      pathType: File
etcd:
  local:
    extraArgs:
      - name: listen-metrics-urls
        value: http://0.0.0.0:2381
---
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration
cgroupDriver: systemd
maxPods: 150
serializeImagePulls: false
seccompDefault: true
allowedUnsafeSysctls:
  - net.ipv4.*
  - net.ipv6.*
