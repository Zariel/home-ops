class Proxmox {
  host: String
  storage: String
  bridge: String
  vmid_base: Int = 9300
  memory_mb: Int = 8192
  cores: Int = 4
  os_disk_gb: Int = 64
  extra_disks_gb: Listing<Int> = new Listing {}
  tags: Listing<String> = new Listing {}
  start: Boolean = true
}

class VM {
  name: String
  mac: String? = null
  vmid: Int? = null
  memory_mb: Int? = null
  cores: Int? = null
  cpu: String? = null
  os_disk_gb: Int? = null
  extra_disks_gb: Listing<Int>? = null
  start: Boolean? = null
  tags: Listing<String>? = null
  nics: Listing<Dynamic>? = null
}

proxmox = new Proxmox {
  host = "root@proxmox.example"
  storage = "local-lvm"
  bridge = "vmbr0"
  extra_disks_gb {
    64
  }
  tags {
    "flatcar-lab"
  }
}

vms = new Listing {
  new VM {
    name = "flatcar-lab-0"
    mac = "52:54:00:93:00:10"
  }
  new VM {
    name = "flatcar-lab-1"
    mac = "52:54:00:93:00:11"
  }
  new VM {
    name = "flatcar-lab-2"
    mac = "52:54:00:93:00:12"
  }
}
